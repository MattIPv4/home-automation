              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "speedtest"
                      },
                      "group": "grafana-postgresql-datasource",
                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT\n  CASE\n    WHEN ${metric:singlequote} IN ('download', 'upload') THEN ${metric:raw} * 8.0 / 1000.0 / 1000.0\n    ELSE ${metric:raw}\n  END AS metric,\n  created_at\nFROM results\nWHERE \n  status = 'completed'\n  AND $__timeFilter(created_at)\nORDER BY created_at DESC "
                      },
                      "version": "v0"
                    },
                    "refId": "Data"
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "config"
                      },
                      "group": "yesoreyeram-infinity-datasource",
                      "kind": "DataQuery",
                      "spec": {
                        "columns": [],
