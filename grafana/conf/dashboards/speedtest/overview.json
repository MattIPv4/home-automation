                        "editorMode": "builder",
                        "filters": [],
                        "format": "table",
                        "global_query_id": "",
                        "parser": "backend",
                        "rawSql": "",
                        "referenceName": "config.json",
                        "root_selector": "$.speedtest.${metric:raw}",
                        "source": "reference",
                        "type": "json",
