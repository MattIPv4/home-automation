{
  "kind": "Dashboard",
  "apiVersion": "dashboard.grafana.app/v2",
  "spec": {
    "cursorSync": "Off",
    "editable": false,
    "elements": {
      "queries": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "postgres"
                      },
                      "group": "grafana-postgresql-datasource",
                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT\n  users.usename AS user,\n  stat.query,\n  stat.calls,\n  stat.rows,\n  stat.min_exec_time,\n  stat.max_exec_time,\n  stat.mean_exec_time,\n  stat.total_exec_time\nFROM pg_stat_statements stat\nJOIN pg_user users ON stat.userid = users.usesysid\nWHERE stat.dbid IN (SELECT oid FROM pg_database WHERE datname = ${selected_database:singlequote}) AND users.usesysid IN (${selected_user:singlequote})\nORDER BY stat.calls DESC"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "description": "",
          "id": 1,
          "links": [],
          "title": "Query Stats",
          "vizConfig": {
            "group": "table",
            "kind": "VizConfig",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "custom": {
                    "align": "auto",
                    "cellOptions": {
                      "type": "auto"
                    },
                    "filterable": false,
                    "footer": {
                      "reducers": []
                    },
                    "inspect": false,
                    "minWidth": 0,
                    "wrapHeaderText": false,
                    "wrapText": false
                  },
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "color": "green",
                        "value": 0
                      }
                    ]
                  }
                },
                "overrides": [
                  {
                    "matcher": {
                      "id": "byRegexp",
                      "options": ".+_time"
                    },
                    "properties": [
                      {
                        "id": "unit",
                        "value": "ms"
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byName",
                      "options": "calls"
                    },
                    "properties": [
                      {
                        "id": "unit",
                        "value": "locale"
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byName",
                      "options": "rows"
                    },
                    "properties": [
                      {
                        "id": "unit",
                        "value": "locale"
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byName",
                      "options": "query"
                    },
                    "properties": [
                      {
                        "id": "custom.inspect",
                        "value": true
                      }
                    ]
                  }
                ]
              },
              "options": {
                "cellHeight": "sm",
                "frameIndex": 1,
                "showHeader": true,
                "sortBy": [
                  {
                    "desc": true,
                    "displayName": "calls"
                  }
                ]
              }
            },
            "version": "13.0.1"
          }
        }
      },
      "tables": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "${selected_datasource}"
                      },
                      "group": "grafana-postgresql-datasource",
                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT\n  table_name AS name,\n  table_size AS size,\n  (xpath('/row/c/text()', query_to_xml(format('SELECT COUNT(*) AS c FROM %I', table_name), FALSE, TRUE, '')))[1]::text::int AS rows\nFROM (\n    SELECT\n      table_name,\n      pg_total_relation_size(quote_ident(table_name)) AS table_size\n    FROM information_schema.tables\n    WHERE table_schema = 'public'\n    ORDER BY 2 DESC\n) AS tables"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "description": "",
          "id": 2,
          "links": [],
          "title": "Table Sizes",
          "vizConfig": {
            "group": "table",
            "kind": "VizConfig",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "custom": {
                    "align": "auto",
                    "cellOptions": {
                      "type": "auto"
                    },
                    "footer": {
                      "reducers": []
                    },
                    "inspect": false
                  },
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "color": "green",
                        "value": 0
                      }
                    ]
                  }
                },
                "overrides": [
                  {
                    "matcher": {
                      "id": "byName",
                      "options": "size"
                    },
                    "properties": [
                      {
                        "id": "unit",
                        "value": "bytes"
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byName",
                      "options": "rows"
                    },
                    "properties": [
                      {
                        "id": "unit",
                        "value": "locale"
                      }
                    ]
                  }
                ]
              },
              "options": {
                "cellHeight": "sm",
                "frameIndex": 0,
                "showHeader": true,
                "sortBy": [
                  {
                    "desc": true,
                    "displayName": "size"
                  }
                ]
              }
            },
            "version": "13.0.1"
          }
        }
      },
      "db-size": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "${selected_datasource}"
                      },
                      "group": "grafana-postgresql-datasource",
                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT current_database() AS db, pg_database_size(current_database()) AS db_size;"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": [
                {
                  "group": "rowsToFields",
                  "kind": "Transformation",
                  "spec": {
                    "options": {
                      "mappings": [
                        {
                          "fieldName": "db",
                          "handlerKey": "field.name"
                        },
                        {
                          "fieldName": "db_size",
                          "handlerKey": "field.value"
                        }
                      ]
                    }
                  }
                }
              ]
            }
          },
          "description": "",
          "id": 3,
          "links": [],
          "title": "Database Size",
          "vizConfig": {
            "group": "stat",
            "kind": "VizConfig",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "color": {
                    "mode": "thresholds"
                  },
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "color": "blue",
                        "value": 0
                      }
                    ]
                  },
                  "unit": "bytes"
                },
                "overrides": []
              },
              "options": {
                "colorMode": "value",
                "graphMode": "area",
                "justifyMode": "center",
                "orientation": "auto",
                "percentChangeColorMode": "standard",
                "reduceOptions": {
                  "calcs": [
                    "lastNotNull"
                  ],
                  "fields": "",
                  "values": false
                },
                "showPercentChange": false,
                "textMode": "value_and_name",
                "wideLayout": false
              }
            },
            "version": "13.0.1"
          }
        }
      },
      "db-version": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "postgres"
                      },
                      "group": "grafana-postgresql-datasource",
                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT substring(current_setting('server_version') FROM '^\\d+\\.\\d+')::numeric AS version;"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "description": "",
          "id": 4,
          "links": [],
          "title": "Database Version",
          "vizConfig": {
            "group": "stat",
            "kind": "VizConfig",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "color": {
                    "mode": "thresholds"
                  },
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "color": "blue",
                        "value": 0
                      }
                    ]
                  },
                  "unit": "string"
                },
                "overrides": []
              },
              "options": {
                "colorMode": "value",
                "graphMode": "area",
                "justifyMode": "auto",
                "orientation": "auto",
                "percentChangeColorMode": "standard",
                "reduceOptions": {
                  "calcs": [
                    "lastNotNull"
                  ],
                  "fields": "",
                  "values": false
                },
                "showPercentChange": false,
                "textMode": "auto",
                "wideLayout": true
              }
            },
            "version": "13.0.1"
          }
        }
      },
      "db-uptime": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "postgres"
                      },
                      "group": "grafana-postgresql-datasource",
                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT  to_char(pg_postmaster_start_time(), 'YYYY-MM-DD HH:MI:SS') AS start, extract('epoch' FROM (now() - pg_postmaster_start_time())) AS uptime;"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": [
                {
                  "group": "rowsToFields",
                  "kind": "Transformation",
                  "spec": {
                    "options": {
                      "mappings": [
                        {
                          "fieldName": "start",
                          "handlerKey": "field.name"
                        },
                        {
                          "fieldName": "uptime",
                          "handlerKey": "field.value"
                        }
                      ]
                    }
                  }
                }
              ]
            }
          },
          "description": "",
          "id": 5,
          "links": [],
          "title": "Database Uptime",
          "vizConfig": {
            "group": "stat",
            "kind": "VizConfig",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "color": {
                    "mode": "thresholds"
                  },
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "color": "blue",
                        "value": 0
                      }
                    ]
                  },
                  "unit": "s"
                },
                "overrides": []
              },
              "options": {
                "colorMode": "value",
                "graphMode": "area",
                "justifyMode": "center",
                "orientation": "auto",
                "percentChangeColorMode": "standard",
                "reduceOptions": {
                  "calcs": [
                    "lastNotNull"
                  ],
                  "fields": "",
                  "values": false
                },
                "showPercentChange": false,
                "textMode": "value_and_name",
                "wideLayout": false
              }
            },
            "version": "13.0.1"
          }
        }
      }
    },
    "layout": {
      "kind": "GridLayout",
      "spec": {
        "items": [
          {
            "kind": "GridLayoutItem",
            "spec": {
              "element": {
                "kind": "ElementReference",
                "name": "queries"
              },
              "height": 13,
              "width": 24,
              "x": 0,
              "y": 0
            }
          },
          {
            "kind": "GridLayoutItem",
            "spec": {
              "element": {
                "kind": "ElementReference",
                "name": "tables"
              },
              "height": 12,
              "width": 20,
              "x": 0,
              "y": 13
            }
          },
          {
            "kind": "GridLayoutItem",
            "spec": {
              "element": {
                "kind": "ElementReference",
                "name": "db-size"
              },
              "height": 4,
              "width": 4,
              "x": 20,
              "y": 13
            }
          },
          {
            "kind": "GridLayoutItem",
            "spec": {
              "element": {
                "kind": "ElementReference",
                "name": "db-version"
              },
              "height": 4,
              "width": 4,
              "x": 20,
              "y": 17
            }
          },
          {
            "kind": "GridLayoutItem",
            "spec": {
              "element": {
                "kind": "ElementReference",
                "name": "db-uptime"
              },
              "height": 4,
              "width": 4,
              "x": 20,
              "y": 21
            }
          }
        ]
      }
    },
    "links": [],
    "liveNow": false,
    "preload": false,
    "tags": [],
    "timeSettings": {
      "autoRefresh": "1m",
      "fiscalYearStartMonth": 0,
      "from": "now",
      "hideTimepicker": true,
      "timezone": "browser",
      "to": "now"
    },
    "title": "Postgres Stats",
    "variables": [
      {
        "kind": "DatasourceVariable",
        "spec": {
          "allowCustomValue": false,
          "current": {
            "text": "Postgres",
            "value": "postgres"
          },
          "hide": "dontHide",
          "includeAll": false,
          "label": "Database",
          "multi": false,
          "name": "selected_datasource",
          "options": [],
          "pluginId": "grafana-postgresql-datasource",
          "refresh": "onDashboardLoad",
          "regex": "",
          "skipUrlSync": false
        }
      },
      {
        "kind": "QueryVariable",
        "spec": {
          "allowCustomValue": false,
          "current": {
            "text": "postgres",
            "value": "postgres"
          },
          "definition": "SELECT current_database()",
          "hide": "hideVariable",
          "includeAll": false,
          "multi": false,
          "name": "selected_database",
          "options": [],
          "query": {
            "datasource": {
              "name": "${selected_datasource}"
            },
            "group": "grafana-postgresql-datasource",
            "kind": "DataQuery",
            "spec": {
              "__legacyStringValue": "SELECT current_database()"
            },
            "version": "v0"
          },
          "refresh": "onDashboardLoad",
          "regex": "",
          "regexApplyTo": "value",
          "skipUrlSync": false,
          "sort": "disabled"
        }
      },
      {
        "kind": "QueryVariable",
        "spec": {
          "allowCustomValue": false,
          "current": {
            "text": "All",
            "value": [
              "$__all"
            ]
          },
          "definition": "SELECT usename || '|' || usesysid FROM pg_user",
          "hide": "dontHide",
          "includeAll": true,
          "label": "User",
          "multi": true,
          "name": "selected_user",
          "options": [],
          "query": {
            "datasource": {
              "name": "postgres"
            },
            "group": "postgres",
            "kind": "DataQuery",
            "spec": {
              "__legacyStringValue": "SELECT usename || '|' || usesysid FROM pg_user"
            },
            "version": "v0"
          },
          "refresh": "onDashboardLoad",
          "regex": "/^(?<text>.*)\\|(?<value>.*)$/",
          "regexApplyTo": "value",
          "skipUrlSync": false,
          "sort": "alphabeticalAsc"
        }
      }
    ]
  }
}
