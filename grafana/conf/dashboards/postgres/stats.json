              {
                "params": [
                  "min_time"
                ],
                "type": "column"
              }
            ],
            [
              {
                "params": [
                  "max_time"
                ],
                "type": "column"
              }
            ],
            [
              {
                "params": [
                  "mean_time"
                ],
                "type": "column"
              }
            ]
          ],
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
